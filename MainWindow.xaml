<Window x:Class="WinNetManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WinNetManager.Views"
        Title="WinNetManager - Windows 网络管理工具" Height="620" Width="960"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        Icon="netfol.ico"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Expander DockPanel.Dock="Bottom" x:Name="CmdPreviewExpander" Header="命令预览" IsExpanded="False"
                  BorderBrush="#DDD" BorderThickness="0,1,0,0" Background="#FAFAFA">
            <TextBox x:Name="TxtCommandPreview" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                     Background="#FAFAFA" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     MaxHeight="100" Padding="6,4" BorderThickness="0"/>
        </Expander>
        <StatusBar DockPanel.Dock="Bottom" Padding="4,3">
            <TextBlock x:Name="StatusText" Text="就绪" VerticalAlignment="Center"/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Button Content="网络适配器" Padding="8,2" FontSize="11" Click="BtnNcpa_Click"
                            ToolTip="打开 控制面板\网络连接 (ncpa.cpl)"/>
                    <Button Content="设备管理器" Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="BtnDevMgr_Click"
                            ToolTip="打开设备管理器 (devmgmt.msc)"/>
                    <Button Content="备份注册表" Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="BtnBackup_Click"
                            ToolTip="一键备份所有网络相关注册表"/>
                    <Button Content="防火墙" Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="BtnFirewall_Click"
                            ToolTip="打开 Windows Defender 防火墙高级安全 (wf.msc)"/>
                    <Button Content="Hosts" Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="BtnHosts_Click"
                            ToolTip="以管理员身份编辑 Hosts 文件"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
        <TabControl x:Name="TabControl" Margin="6">
            <TabItem Header="网络配置文件">
                <views:NetworkProfileTab x:Name="ProfileTab" />
            </TabItem>
            <TabItem Header="连接名称">
                <views:ConnectionNameTab x:Name="ConnectionTab" />
            </TabItem>
            <TabItem Header="设备描述">
                <views:DeviceDescriptionTab x:Name="DescriptionTab" />
            </TabItem>
            <TabItem Header="幽灵网卡">
                <views:GhostAdapterTab x:Name="GhostTab" />
            </TabItem>
            <TabItem Header="持久路由">
                <views:PersistentRouteTab x:Name="RouteTab" />
            </TabItem>
            <TabItem Header="端口转发">
                <views:PortProxyTab x:Name="ProxyTab" />
            </TabItem>
            <TabItem Header="IP 配置">
                <views:DhcpTab x:Name="DhcpTab" />
            </TabItem>
            <TabItem Header="DNS">
                <views:DnsTab x:Name="DnsTab" />
            </TabItem>
            <TabItem Header="网络诊断">
                <views:NetworkDiagTab x:Name="DiagTab" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
