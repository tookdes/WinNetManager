<Window x:Class="WinNetManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WinNetManager.Views"
        Title="WinNetManager - Windows 网络名称管理" Height="620" Width="900"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        Icon="netfol.ico">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom" Padding="4,3">
            <TextBlock x:Name="StatusText" Text="就绪" VerticalAlignment="Center"/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Button Content="网络适配器" Padding="8,2" FontSize="11" Click="BtnNcpa_Click"
                            ToolTip="打开 控制面板\网络连接 (ncpa.cpl)"/>
                    <Button Content="设备管理器" Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="BtnDevMgr_Click"
                            ToolTip="打开设备管理器 (devmgmt.msc)"/>
                    <Button Content="备份注册表" Padding="8,2" FontSize="11" Margin="6,0,0,0" Click="BtnBackup_Click"
                            ToolTip="一键备份所有网络相关注册表"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
        <TabControl Margin="6">
            <TabItem Header="网络配置文件">
                <views:NetworkProfileTab x:Name="ProfileTab" />
            </TabItem>
            <TabItem Header="连接名称">
                <views:ConnectionNameTab x:Name="ConnectionTab" />
            </TabItem>
            <TabItem Header="设备描述">
                <views:DeviceDescriptionTab x:Name="DescriptionTab" />
            </TabItem>
            <TabItem Header="幽灵网卡">
                <views:GhostAdapterTab x:Name="GhostTab" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
