<UserControl x:Class="WinNetManager.Views.PortProxyTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="刷新" Padding="12,4" Click="BtnRefresh_Click"/>
            <Button Content="全选" Padding="8,4" Margin="6,0,0,0" Click="BtnSelectAll_Click"/>
            <Button Content="反选" Padding="8,4" Margin="4,0,0,0" Click="BtnInvertSelection_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <Button Content="新建" Padding="12,4" Margin="6,0,0,0" Click="BtnNew_Click"/>
            <Button Content="修改" Padding="12,4" Margin="6,0,0,0" Click="BtnEdit_Click"/>
            <Button Content="删除" Padding="12,4" Margin="6,0,0,0" Foreground="Red" Click="BtnDelete_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <ComboBox x:Name="CmbDirection" Width="80" Padding="2,2" Margin="4,0,0,0" VerticalContentAlignment="Center" SelectionChanged="CmbDirection_SelectionChanged">
                <ComboBoxItem Content="全部" Tag="" IsSelected="True"/>
                <ComboBoxItem Content="IPv4→IPv4" Tag="v4tov4"/>
                <ComboBoxItem Content="IPv4→IPv6" Tag="v4tov6"/>
                <ComboBoxItem Content="IPv6→IPv4" Tag="v6tov4"/>
                <ComboBoxItem Content="IPv6→IPv6" Tag="v6tov6"/>
            </ComboBox>
            <TextBox x:Name="TxtFilter" Width="80" Margin="4,0,0,0" Padding="4,2"
                     TextChanged="TxtFilter_TextChanged" ToolTip="筛选监听地址、目标地址、端口"/>
            <Button Content="清除" Padding="8,4" Margin="4,0,0,0" Click="BtnClearFilter_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <Button Content="导出" Padding="10,4" Margin="6,0,0,0" Click="BtnExport_Click"/>
            <Button Content="导入" Padding="10,4" Margin="4,0,0,0" Click="BtnImport_Click"/>
        </StackPanel>
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="Gray"
                       Text="管理 Windows 端口转发规则（netsh interface portproxy），支持 IPv4/IPv6 四种方向。依赖 IP Helper 服务。"/>
            <TextBlock x:Name="TbkCount" DockPanel.Dock="Right" FontSize="11" Foreground="Gray" HorizontalAlignment="Right"/>
        </DockPanel>
        <TextBlock x:Name="TbkServiceWarning" DockPanel.Dock="Top" Margin="0,0,0,6" FontSize="11" Foreground="OrangeRed"
                   Text="警告：IP Helper 服务未运行，端口转发规则不会生效。" Visibility="Collapsed"/>
        <Grid>
            <DataGrid x:Name="ProxyGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                      IsReadOnly="True" SelectionMode="Extended" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" AlternatingRowBackground="#F8F8F8"
                      ColumnWidth="Auto" Sorting="Grid_Sorting">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="新建" Click="BtnNew_Click"/>
                        <MenuItem Header="修改" Click="BtnEdit_Click"/>
                        <Separator/>
                        <MenuItem Header="删除" Click="BtnDelete_Click" Foreground="Red"/>
                        <Separator/>
                        <MenuItem Header="复制选中值" Click="MenuCopy_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Direction}" Width="Auto">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="方向" ToolTip="v4tov4 / v4tov6 / v6tov4 / v6tov6，表示监听端与目标端的 IP 协议版本"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding ListenAddress}" Header="监听地址" Width="Auto"/>
                    <DataGridTextColumn Binding="{Binding ListenPort}" Header="监听端口" Width="Auto"/>
                    <DataGridTextColumn Binding="{Binding ConnectAddress}" Header="目标地址" Width="Auto"/>
                    <DataGridTextColumn Binding="{Binding ConnectPort}" Header="目标端口" Width="Auto"/>
                    <DataGridTextColumn Binding="{Binding Protocol}" Header="协议" Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>
            <Border x:Name="EmptyState" Background="#FAFAFA" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50">
                    <TextBlock Text="&#x1F500;" FontSize="48" HorizontalAlignment="Center" Foreground="#CCC" FontFamily="Segoe UI Emoji"/>
                    <TextBlock Text="暂无端口转发规则" FontSize="16" Foreground="#666" HorizontalAlignment="Center" Margin="0,12,0,4" FontWeight="SemiBold"/>
                    <TextBlock Text="当前没有配置任何端口转发规则。点击「新建」添加一条，依赖 IP Helper 服务。" FontSize="12" Foreground="#999" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="420"/>
                    <Button Content="新建" Padding="16,4" Margin="0,16,0,0" HorizontalAlignment="Center" Click="BtnNew_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
