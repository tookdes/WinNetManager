<UserControl x:Class="WinNetManager.Views.InterfaceMetricTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <!-- 工具栏 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="刷新" Padding="12,4" Click="BtnRefresh_Click"/>
            <Button Content="全选" Padding="8,4" Margin="6,0,0,0" Click="BtnSelectAll_Click"/>
            <Button Content="反选" Padding="8,4" Margin="4,0,0,0" Click="BtnInvertSelection_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <Button Content="修改跃点" Padding="12,4" Margin="6,0,0,0" Click="BtnEdit_Click" ToolTip="为选中的网卡设置指定跃点数 (F2)"/>
            <Button Content="设为自动跃点" Padding="12,4" Margin="6,0,0,0" Click="BtnAuto_Click" ToolTip="为选中的网卡启用自动跃点"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <ComboBox x:Name="CmbAddressFamily" Width="52" Padding="2,2" Margin="4,0,0,0"
                      VerticalContentAlignment="Center" SelectionChanged="CmbAddressFamily_SelectionChanged">
                <ComboBoxItem Content="全部" Tag="" IsSelected="True"/>
                <ComboBoxItem Content="IPv4" Tag="IPv4"/>
                <ComboBoxItem Content="IPv6" Tag="IPv6"/>
            </ComboBox>
            <TextBox x:Name="TxtFilter" Width="100" Margin="4,0,0,0" Padding="4,2"
                     TextChanged="TxtFilter_TextChanged" ToolTip="按网卡名称筛选"/>
            <Button Content="清除" Padding="8,4" Margin="4,0,0,0" Click="BtnClearFilter_Click"/>
        </StackPanel>

        <!-- 描述 + 计数 -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="Gray"
                       Text="管理每个网卡的 IPv4/IPv6 接口跃点数，决定多网卡路由优先级"/>
            <TextBlock x:Name="TbkCount" DockPanel.Dock="Right" FontSize="11" Foreground="Gray" HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- 表格 + 空状态 -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="MetricGrid"
                      Grid.Row="0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#F8F8F8"
                      ColumnWidth="Auto"
                      Sorting="Grid_Sorting">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding InterfaceAlias}" Width="200">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="网卡名称" ToolTip="网络接口别名，如 以太网、WLAN"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding AddressFamily}" Width="80">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="协议" ToolTip="IPv4 或 IPv6"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding InterfaceIndex}" Width="80">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="接口索引" ToolTip="系统分配的接口编号 (IfIndex)"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding AutoDisplay}" Width="80">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="自动跃点" ToolTip="是否由 Windows 自动计算跃点数"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding InterfaceMetric}" Width="100">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="跃点数" ToolTip="数值越小，路由优先级越高"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="修改跃点" Click="BtnEdit_Click"/>
                        <MenuItem Header="设为自动跃点" Click="BtnAuto_Click"/>
                        <Separator/>
                        <MenuItem Header="复制选中值" Click="MenuCopy_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#EEE"/>

            <DockPanel Grid.Row="2" Margin="0,4,0,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                    <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="Gray" Text="默认网关跃点 (0.0.0.0 / ::/0)"/>
                    <TextBlock x:Name="TbkGatewayCount" DockPanel.Dock="Right" FontSize="11" Foreground="Gray" HorizontalAlignment="Right"/>
                </DockPanel>
                <DataGrid x:Name="GatewayGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#F8F8F8"
                          ColumnWidth="Auto"
                          Sorting="GatewayGrid_Sorting">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding InterfaceAlias}" Width="200" Header="网卡名称"/>
                        <DataGridTextColumn Binding="{Binding AddressFamily}" Width="80" Header="协议"/>
                        <DataGridTextColumn Binding="{Binding InterfaceIndex}" Width="80" Header="接口索引"/>
                        <DataGridTextColumn Binding="{Binding NextHop}" Width="150" Header="网关地址"/>
                        <DataGridTextColumn Binding="{Binding RouteMetric}" Width="100" Header="路由跃点数"/>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="修改网关跃点" Click="BtnEditGateway_Click"/>
                            <Separator/>
                            <MenuItem Header="复制选中值" Click="MenuCopyGateway_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </DockPanel>

            <Border x:Name="EmptyState" Grid.RowSpan="3" Background="#FAFAFA" Visibility="Collapsed" Panel.ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50">
                    <TextBlock Text="&#x1F4CA;" FontSize="48" HorizontalAlignment="Center"
                               Foreground="#CCC" FontFamily="Segoe UI Emoji"/>
                    <TextBlock Text="暂无网卡跃点信息" FontSize="16" Foreground="#666"
                               HorizontalAlignment="Center" Margin="0,12,0,4" FontWeight="SemiBold"/>
                    <TextBlock Text="未检测到活动的网络接口，请检查网卡状态。" FontSize="12" Foreground="#999"
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="420"/>
                    <Button Content="刷新" Padding="16,4" Margin="0,16,0,0"
                            HorizontalAlignment="Center" Click="BtnRefresh_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
