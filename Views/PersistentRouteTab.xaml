<UserControl x:Class="WinNetManager.Views.PersistentRouteTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="刷新" Padding="12,4" Click="BtnRefresh_Click"/>
            <Button Content="全选" Padding="8,4" Margin="6,0,0,0" Click="BtnSelectAll_Click"/>
            <Button Content="反选" Padding="8,4" Margin="4,0,0,0" Click="BtnInvertSelection_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <Button Content="新建" Padding="12,4" Margin="6,0,0,0" Click="BtnNew_Click"/>
            <Button Content="修改" Padding="12,4" Margin="6,0,0,0" Click="BtnEdit_Click"/>
            <Button Content="删除" Padding="12,4" Margin="6,0,0,0" Foreground="Red" Click="BtnDelete_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <Button x:Name="BtnApply" Content="应用更改" Padding="12,4" Margin="6,0,0,0" Click="BtnApply_Click"/>
            <Button x:Name="BtnCancelChanges" Content="取消更改" Padding="12,4" Margin="6,0,0,0" Click="BtnCancelChanges_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <ComboBox x:Name="CmbAddressFamily" Width="52" Padding="2,2" Margin="4,0,0,0" VerticalContentAlignment="Center" SelectionChanged="CmbAddressFamily_SelectionChanged">
                <ComboBoxItem Content="全部" Tag="" IsSelected="True"/>
                <ComboBoxItem Content="IPv4" Tag="IPv4"/>
                <ComboBoxItem Content="IPv6" Tag="IPv6"/>
            </ComboBox>
            <TextBox x:Name="TxtFilter" Width="80" Margin="4,0,0,0" Padding="4,2"
                     TextChanged="TxtFilter_TextChanged" ToolTip="筛选目标前缀、下一跳、接口等"/>
            <Button Content="清除" Padding="8,4" Margin="4,0,0,0" Click="BtnClearFilter_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <Button Content="导出" Padding="10,4" Margin="6,0,0,0" Click="BtnExport_Click"/>
            <Button Content="导入" Padding="10,4" Margin="4,0,0,0" Click="BtnImport_Click"/>
        </StackPanel>

        <DockPanel Grid.Row="1" Margin="0,0,0,6">
            <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="Gray"
                       Text="管理 Windows 持久路由（重启后仍然保留的路由）。新建/修改/删除后需点击「应用更改」才能写入系统。"/>
            <TextBlock x:Name="TbkCount" DockPanel.Dock="Right" FontSize="11" Foreground="Gray" HorizontalAlignment="Right"/>
        </DockPanel>

        <Grid Grid.Row="2">
            <DataGrid x:Name="RoutesGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                      IsReadOnly="True" SelectionMode="Extended" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" AlternationCount="2"
                      ColumnWidth="Auto" Sorting="Grid_Sorting">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="新建" Click="BtnNew_Click"/>
                        <MenuItem Header="修改" Click="BtnEdit_Click"/>
                        <Separator/>
                        <MenuItem Header="删除" Click="BtnDelete_Click" Foreground="Red"/>
                        <Separator/>
                        <MenuItem Header="复制选中值" Click="MenuCopy_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#F8F8F8"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Status}" Value="Modified">
                                <Setter Property="Background" Value="#FFF9E6"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Added">
                                <Setter Property="Background" Value="#E6F9E6"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Deleted">
                                <Setter Property="Background" Value="#F4F4F4"/>
                                <Setter Property="Foreground" Value="#AAA"/>
                                <Setter Property="FontStyle" Value="Italic"/>
                                <Setter Property="Opacity" Value="0.6"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding AddressFamily}" Width="Auto">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="地址族" ToolTip="IPv4 或 IPv6，决定路由使用的网络协议版本"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding DestinationDisplay}" Width="Auto">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="目标前缀" ToolTip="目标网络的 CIDR 表示，如 192.168.1.0/24 或 default"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding NextHopDisplay}" Width="Auto">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="下一跳" ToolTip="数据包到达目标网络前，首先转发到的路由器地址"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding InterfaceAlias}" Width="Auto">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="接口别名" ToolTip="网卡显示名称，如「以太网」或「WLAN」"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding InterfaceIndex}" Width="Auto">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="接口索引" ToolTip="系统内部接口编号，用于唯一标识网卡"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding RouteMetric}" Width="Auto">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="度量值" ToolTip="路由优先级，数值越小优先级越高；默认 256"/>
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
            <Border x:Name="EmptyState" Background="#FAFAFA" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
                    <TextBlock Text="&#x1F6E3;" FontSize="48" HorizontalAlignment="Center" Foreground="#CCC" FontFamily="Segoe UI Emoji"/>
                    <TextBlock Text="暂无持久路由" FontSize="16" Foreground="#666" HorizontalAlignment="Center" Margin="0,12,0,4" FontWeight="SemiBold"/>
                    <TextBlock Text="当前没有配置任何持久路由。点击「新建」添加一条，重启后仍然生效。" FontSize="12" Foreground="#999" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="420"/>
                    <Button Content="新建" Padding="16,4" Margin="0,16,0,0" HorizontalAlignment="Center" Click="BtnNew_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <GroupBox Grid.Row="3" Header="路由测试" Margin="0,8,0,0">
            <DockPanel Margin="6">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBox x:Name="TxtTestTarget" Width="200" Padding="4,2"
                             ToolTip="输入目标 IP 地址或域名"/>
                    <Button Content="测试路由" Padding="10,3" Margin="6,0,0,0" Click="BtnRouteTest_Click"/>
                </StackPanel>
                <TextBox x:Name="TxtTestResult" IsReadOnly="True"
                         Background="#F8F8F8" FontFamily="Consolas" FontSize="12"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         MaxHeight="80">
                    <TextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制全部" Click="MenuCopyAllTest_Click"/>
                            <MenuItem Header="复制选中" Click="MenuCopySelectedTest_Click"/>
                        </ContextMenu>
                    </TextBox.ContextMenu>
                </TextBox>
            </DockPanel>
        </GroupBox>
    </Grid>
</UserControl>
