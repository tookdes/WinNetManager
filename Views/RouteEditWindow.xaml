<Window x:Class="WinNetManager.Views.RouteEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑路由" Height="400" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="../netfol.ico"
        >
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="地址族：" VerticalAlignment="Center" />
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CmbAddressFamily" Margin="5"
                  SelectionChanged="CmbAddressFamily_SelectionChanged">
            <ComboBoxItem Content="IPv4" Tag="IPv4" />
            <ComboBoxItem Content="IPv6" Tag="IPv6" />
        </ComboBox>

        <Label Grid.Row="1" Grid.Column="0" Content="目标前缀：" VerticalAlignment="Center" />
        <Grid Grid.Row="1" Grid.Column="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="TxtDestinationPrefix"
                     TextChanged="TxtDestinationPrefix_TextChanged"
                     ToolTip="输入 IP 地址后从右侧下拉框选择覆盖范围&#x0a;或直接输入完整 CIDR（如 10.0.0.0/7、192.168.1.0/24）" />
            <Label Grid.Column="1" x:Name="LblSlash" Content=" /" VerticalAlignment="Center" />
            <ComboBox Grid.Column="2" x:Name="CmbPrefixLength" Width="160"
                      SelectionChanged="CmbPrefixLength_SelectionChanged" />
        </Grid>

        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TbkPrefixInfo"
                   FontSize="11" Margin="5,0,5,4" TextWrapping="Wrap" Foreground="DarkGreen" />

        <Label Grid.Row="3" Grid.Column="0" Content="下一跳：" VerticalAlignment="Center" />
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtNextHop" Margin="5"
                 ToolTip="IPv4 示例：192.168.1.1&#x0a;IPv6 示例：fe80::1 或 ::" />

        <Label Grid.Row="4" Grid.Column="0" Content="接口别名：" VerticalAlignment="Center" />
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="CmbInterface" Margin="5"
                  IsEditable="True"
                  ToolTip="从列表中选择或手动输入接口名称" />

        <Label Grid.Row="5" Grid.Column="0" Content="度量值：" VerticalAlignment="Center" />
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="TxtMetric" Margin="5" Text="1" />

        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="提示：IPv4 默认路由使用 0.0.0.0/0，IPv6 默认路由使用 ::/0"
                   Foreground="Gray" FontSize="11" Margin="5,10,5,0" TextWrapping="Wrap" />
        <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="覆盖范围下拉框仅辅助选择掩码；熟悉 CIDR 的用户可直接在左侧输入完整的 192.168.1.0/24 格式。"
                   Foreground="Gray" FontSize="11" Margin="5,0,5,0" TextWrapping="Wrap" />

        <Button Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" x:Name="BtnToggleCalc"
                Content="不知道掩码？使用范围计算器" Padding="8,2" FontSize="11" Margin="5,2"
                HorizontalAlignment="Left" Click="BtnToggleCalc_Click" />

        <Grid Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" x:Name="GridCalc" Visibility="Collapsed" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="起始 IP：" VerticalAlignment="Center" FontSize="11" />
            <TextBox Grid.Column="1" x:Name="TxtCalcStart" FontSize="11" />
            <Label Grid.Column="2" Content="结束 IP：" VerticalAlignment="Center" FontSize="11" Margin="6,0,0,0" />
            <TextBox Grid.Column="3" x:Name="TxtCalcEnd" FontSize="11" />
            <Button Grid.Column="4" Content="计算 CIDR" Padding="8,2" Margin="6,0,0,0" FontSize="11" Click="BtnCalc_Click" />
        </Grid>
        <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" x:Name="TbkCalcResult"
                   FontSize="11" Margin="5,0,5,0" TextWrapping="Wrap" />

        <StackPanel Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnSave" Content="保存" Width="80" Margin="5" IsDefault="True" Click="BtnSave_Click" />
            <Button Content="取消" Width="80" Margin="5" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
