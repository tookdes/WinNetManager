<UserControl x:Class="WinNetManager.Views.DnsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <!-- NRPT 规则管理 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="刷新" Padding="12,4" Click="BtnRefresh_Click"/>
            <Button Content="全选" Padding="8,4" Margin="6,0,0,0" Click="BtnSelectAll_Click"/>
            <Button Content="反选" Padding="8,4" Margin="4,0,0,0" Click="BtnInvertSelection_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <Button Content="修改网卡 DNS" Padding="12,4" Margin="6,0,0,0" Click="BtnEditDns_Click"/>
            <Button Content="设为自动获取" Padding="12,4" Margin="6,0,0,0" Click="BtnAutoDns_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <Button Content="新建 NRPT 规则" Padding="12,4" Margin="6,0,0,0" Click="BtnAdd_Click"/>
            <Button Content="删除 NRPT" Padding="12,4" Margin="6,0,0,0" Foreground="Red" Click="BtnDelete_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <ComboBox x:Name="CmbAddressFamily" Width="52" Padding="2,2" Margin="4,0,0,0"
                      VerticalContentAlignment="Center" SelectionChanged="CmbAddressFamily_SelectionChanged">
                <ComboBoxItem Content="全部" Tag="" IsSelected="True"/>
                <ComboBoxItem Content="IPv4" Tag="IPv4"/>
                <ComboBoxItem Content="IPv6" Tag="IPv6"/>
            </ComboBox>
            <TextBox x:Name="TxtFilter" Width="100" Margin="4,0,0,0" Padding="4,2"
                     TextChanged="TxtFilter_TextChanged" ToolTip="按名称筛选"/>
            <Button Content="清除" Padding="8,4" Margin="4,0,0,0" Click="BtnClearFilter_Click"/>
        </StackPanel>

        <!-- DNS 小工具吸底 -->
        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 域名解析测试 -->
            <GroupBox Grid.Column="0" Header="域名解析测试">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="TxtResolveDomain" Width="200" Padding="4,2"
                                 ToolTip="输入域名，如 github.com 或 gitlab.corp.local"/>
                        <Button Content="解析" Padding="12,4" Margin="6,0,0,0" Click="BtnResolve_Click"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" FontSize="11" Foreground="Gray" Margin="0,0,0,4"
                               Text="使用 Resolve-DnsName 解析域名，显示 A/AAAA/CNAME 记录。"/>
                    <TextBox x:Name="TxtResolveResult" IsReadOnly="True" Height="60"
                             Background="#F8F8F8" FontFamily="Consolas" FontSize="12"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto">
                        <TextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="复制全部" Click="MenuCopyAllResolve_Click"/>
                                <MenuItem Header="复制选中" Click="MenuCopySelectedResolve_Click"/>
                            </ContextMenu>
                        </TextBox.ContextMenu>
                    </TextBox>
                </DockPanel>
            </GroupBox>

            <!-- DNS 缓存刷新 -->
            <GroupBox Grid.Column="2" Header="DNS 缓存管理">
                <StackPanel Margin="12">
                    <TextBlock FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                               Text="Windows 会缓存 DNS 解析结果以提高速度，但缓存可能导致域名 IP 变更后仍返回旧地址。"/>
                    <Button Content="刷新 DNS 缓存" Padding="12,4" Margin="0,12,0,0" HorizontalAlignment="Left"
                            Click="BtnFlushDns_Click" ToolTip="执行 Clear-DnsClientCache"/>
                    <TextBlock x:Name="TbkFlushResult" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- 上下分屏表格 -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,4">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                    <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="Gray" Text="常规网卡 DNS (Interface DNS)"/>
                    <TextBlock x:Name="TbkDnsCount" DockPanel.Dock="Right" FontSize="11" Foreground="Gray" HorizontalAlignment="Right"/>
                </DockPanel>
                <DataGrid x:Name="InterfaceDnsGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" SelectionMode="Extended" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column" AlternatingRowBackground="#F8F8F8"
                          ColumnWidth="Auto" Sorting="Grid_Sorting">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding InterfaceAlias}" Width="200" Header="网卡名称"/>
                        <DataGridTextColumn Binding="{Binding AddressFamily}" Width="80" Header="协议"/>
                        <DataGridTextColumn Binding="{Binding InterfaceIndex}" Width="80" Header="接口索引"/>
                        <DataGridTextColumn Binding="{Binding ServerAddresses}" Width="*" Header="DNS 服务器"/>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="修改网卡 DNS" Click="BtnEditDns_Click"/>
                            <MenuItem Header="设为自动获取" Click="BtnAutoDns_Click"/>
                            <Separator/>
                            <MenuItem Header="复制选中值" Click="MenuCopyDns_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </DockPanel>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#EEE"/>

            <DockPanel Grid.Row="2" Margin="0,4,0,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                    <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="Gray" Text="高级名称解析策略表 (NRPT)"/>
                    <TextBlock x:Name="TbkNrptCount" DockPanel.Dock="Right" FontSize="11" Foreground="Gray" HorizontalAlignment="Right"/>
                </DockPanel>
                <Grid>
                    <DataGrid x:Name="NrptGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                              IsReadOnly="True" SelectionMode="Extended" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" AlternatingRowBackground="#F8F8F8"
                              ColumnWidth="Auto" Sorting="Grid_Sorting">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Namespace}" Width="200" Header="域名后缀"/>
                            <DataGridTextColumn Binding="{Binding NameServers}" Width="200" Header="DNS 服务器"/>
                            <DataGridTextColumn Binding="{Binding Comment}" Header="备注" Width="100"/>
                            <DataGridTextColumn Binding="{Binding GpoName}" Width="100" Header="GPO"/>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="新建 NRPT 规则" Click="BtnAdd_Click"/>
                                <MenuItem Header="删除 NRPT" Click="BtnDelete_Click" Foreground="Red"/>
                                <Separator/>
                                <MenuItem Header="复制选中值" Click="MenuCopyNrpt_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                    <Border x:Name="EmptyState" Background="#FAFAFA" Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x1F310;" FontSize="36" HorizontalAlignment="Center" Foreground="#CCC" FontFamily="Segoe UI Emoji"/>
                            <TextBlock Text="暂无 NRPT 规则" FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,8,0,2" FontWeight="SemiBold"/>
                            <Button Content="新建 NRPT 规则" Padding="12,3" Margin="0,10,0,0" HorizontalAlignment="Center" Click="BtnAdd_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
