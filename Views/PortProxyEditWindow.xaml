<Window x:Class="WinNetManager.Views.PortProxyEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑端口转发" Height="340" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="../netfol.ico">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="方向：" VerticalAlignment="Center" />
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CmbDirection" Margin="5">
            <ComboBoxItem Content="IPv4 → IPv4" Tag="v4tov4" />
            <ComboBoxItem Content="IPv4 → IPv6" Tag="v4tov6" />
            <ComboBoxItem Content="IPv6 → IPv4" Tag="v6tov4" />
            <ComboBoxItem Content="IPv6 → IPv6" Tag="v6tov6" />
        </ComboBox>

        <Label Grid.Row="1" Grid.Column="0" Content="监听地址：" VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtListenAddress" Margin="5"
                 ToolTip="监听地址，例如 0.0.0.0、127.0.0.1 或 ::" />

        <Label Grid.Row="2" Grid.Column="0" Content="监听端口：" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtListenPort" Margin="5"
                 ToolTip="1 - 65535" />

        <Label Grid.Row="3" Grid.Column="0" Content="目标地址：" VerticalAlignment="Center" />
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtConnectAddress" Margin="5"
                 ToolTip="目标地址，例如 192.168.1.100 或 ::1" />

        <Label Grid.Row="4" Grid.Column="0" Content="目标端口：" VerticalAlignment="Center" />
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtConnectPort" Margin="5"
                 ToolTip="1 - 65535" />

        <Label Grid.Row="5" Grid.Column="0" Content="协议：" VerticalAlignment="Center" />
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="TxtProtocol" Margin="5" Text="tcp"
                 IsReadOnly="True" Background="#F0F0F0" Foreground="Gray"
                 ToolTip="netsh portproxy 仅支持 TCP 协议" />

        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="提示：使用 0.0.0.0 监听所有 IPv4 地址，使用 :: 监听所有 IPv6 地址。"
                   Foreground="Gray" FontSize="11" Margin="5,10,5,0" TextWrapping="Wrap"
                   VerticalAlignment="Bottom" />

        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnSave" Content="保存" Width="80" Margin="5" IsDefault="True" Click="BtnSave_Click" />
            <Button Content="取消" Width="80" Margin="5" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
