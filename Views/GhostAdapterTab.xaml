<UserControl x:Class="WinNetManager.Views.GhostAdapterTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="刷新" Padding="12,4" Click="BtnRefresh_Click"/>
            <Button Content="卸载选中" Padding="12,4" Margin="6,0,0,0" Foreground="Red" Click="BtnRemove_Click"/>
        </StackPanel>
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                   Text="枚举所有网络适配器设备（含设备管理器中隐藏的幽灵设备）。注意：WAN Miniport 等系统虚拟设备虽显示为幽灵，但不应卸载。只卸载你确认已不再使用的物理网卡幽灵条目。"/>
        <DataGrid x:Name="AdapterGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                  SelectionMode="Extended" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" AlternatingRowBackground="#F8F8F8">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="复制选中值" Click="MenuCopy_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="选择" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Binding="{Binding FriendlyName}" Header="设备名称" Width="250" IsReadOnly="True"/>
                <DataGridTextColumn Binding="{Binding StatusDisplay}" Header="状态" Width="70" IsReadOnly="True"/>
                <DataGridTextColumn Binding="{Binding Description}" Header="描述" Width="200" IsReadOnly="True"/>
                <DataGridTextColumn Binding="{Binding DeviceInstanceId}" Header="实例 ID" Width="*" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
