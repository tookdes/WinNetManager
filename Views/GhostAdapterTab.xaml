<UserControl x:Class="WinNetManager.Views.GhostAdapterTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="刷新" Padding="12,4" Click="BtnRefresh_Click"/>
            <Button Content="全选" Padding="8,4" Margin="6,0,0,0" Click="BtnSelectAll_Click"/>
            <Button Content="反选" Padding="8,4" Margin="4,0,0,0" Click="BtnInvertSelection_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <Button Content="卸载选中" Padding="12,4" Margin="6,0,0,0" Foreground="Red" Click="BtnRemove_Click"/>
        </StackPanel>
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                   Text="枚举所有网络适配器设备（含设备管理器中隐藏的幽灵设备）。注意：WAN Miniport 等系统虚拟设备虽显示为幽灵，但不应卸载。Ctrl+点击多选。"/>
        <DataGrid x:Name="AdapterGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" SelectionMode="Extended" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" AlternatingRowBackground="#F8F8F8">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="卸载" Click="BtnRemove_Click" Foreground="Red"/>
                    <Separator/>
                    <MenuItem Header="复制选中值" Click="MenuCopy_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding FriendlyName}" Header="设备名称" Width="250"/>
                <DataGridTextColumn Binding="{Binding StatusDisplay}" Header="状态" Width="70"/>
                <DataGridTextColumn Binding="{Binding Description}" Header="描述" Width="200"/>
                <DataGridTextColumn Binding="{Binding DeviceInstanceId}" Header="实例 ID" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
