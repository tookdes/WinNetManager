<UserControl x:Class="WinNetManager.Views.NetworkDiagTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="刷新" Padding="12,4" Click="BtnRefresh_Click"/>
            <Rectangle Width="1" Fill="#CCC" Margin="10,2"/>
            <Button Content="端口测试" Padding="12,4" Margin="6,0,0,0" Click="BtnPortTest_Click"/>
            <Button Content="Tracert" Padding="12,4" Margin="6,0,0,0" Click="BtnTracert_Click"/>
            <Button Content="Pathping" Padding="12,4" Margin="6,0,0,0" Click="BtnPathping_Click"/>
        </StackPanel>

        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="目标：" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="TxtTarget" Padding="4,2"
                     ToolTip="IP 地址或域名"/>
            <Label Grid.Column="2" Content="端口：" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <TextBox Grid.Column="3" x:Name="TxtPort" Padding="4,2" Text="443"
                     ToolTip="TCP 端口，默认 443"/>
            <TextBlock Grid.Column="4" FontSize="11" Foreground="Gray" Margin="12,0,0,0" VerticalAlignment="Center"
                       Text="Tracert 和 Pathping 将弹出 PowerShell 窗口直接显示输出。"/>
        </Grid>

        <TextBlock DockPanel.Dock="Top" FontSize="11" Foreground="Gray" Margin="0,0,0,6"
                   Text="端口测试使用 Test-NetConnection 检测 TCP 连通性；Tracert / Pathping 调用原生命令弹窗输出。"/>

        <GroupBox Header="当前 TCP 连接（监听 + 已建立）" DockPanel.Dock="Top" Margin="0,0,0,0">
            <Grid>
                <DataGrid x:Name="ConnectionGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" SelectionMode="Extended" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column" AlternatingRowBackground="#F8F8F8"
                          ColumnWidth="Auto" MaxHeight="350">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制选中值" Click="MenuCopy_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding LocalAddress}" Header="本地地址" Width="Auto"/>
                        <DataGridTextColumn Binding="{Binding LocalPort}" Header="本地端口" Width="Auto"/>
                        <DataGridTextColumn Binding="{Binding RemoteAddress}" Header="远程地址" Width="Auto"/>
                        <DataGridTextColumn Binding="{Binding RemotePort}" Header="远程端口" Width="Auto"/>
                        <DataGridTextColumn Binding="{Binding State}" Header="状态" Width="Auto"/>
                        <DataGridTextColumn Binding="{Binding OwningProcess}" Header="进程" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
                <Border x:Name="EmptyState" Background="#FAFAFA" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,30">
                        <TextBlock Text="&#x1F50C;" FontSize="36" HorizontalAlignment="Center" Foreground="#CCC" FontFamily="Segoe UI Emoji"/>
                        <TextBlock Text="暂无 TCP 连接" FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,8,0,2" FontWeight="SemiBold"/>
                        <TextBlock Text="没有检测到监听或已建立的 TCP 连接。" FontSize="11" Foreground="#999" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360"/>
                    </StackPanel>
                </Border>
            </Grid>
        </GroupBox>
    </DockPanel>
</UserControl>
